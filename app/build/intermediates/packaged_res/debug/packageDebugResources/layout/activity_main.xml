<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_main"
    android:padding="16dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.8"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="@color/bg_display"
        app:cardElevation="0dp"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="bottom">

            <TextView
                android:id="@+id/tv_mode_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:text="Mode: Seq"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_base_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:text="Base: DEC"
                android:textColor="@color/btn_base"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_formula"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@color/text_secondary"
                android:textSize="20sp"
                android:maxLines="2"
                android:ellipsize="start" />

            <TextView
                android:id="@+id/tv_display"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="0"
                android:textColor="@color/text_primary"
                android:textSize="44sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btn_dec"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="DEC"
            android:textColor="@color/text_primary"
            android:background="@drawable/btn_base_bg"
            app:backgroundTint="@null"
            android:textStyle="bold"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btn_bin"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="2dp"
            android:text="BIN"
            android:textColor="@color/text_primary"
            android:background="@drawable/btn_base_bg"
            app:backgroundTint="@null"
            android:textStyle="bold"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btn_oct"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="2dp"
            android:text="OCT"
            android:textColor="@color/text_primary"
            android:background="@drawable/btn_base_bg"
            app:backgroundTint="@null"
            android:textStyle="bold"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btn_hex"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="HEX"
            android:textColor="@color/text_primary"
            android:background="@drawable/btn_base_bg"
            app:backgroundTint="@null"
            android:textStyle="bold"
            android:textSize="12sp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="4"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_clear"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="C"
                android:textColor="@color/text_primary"
                android:background="@drawable/btn_action_bg"
                app:backgroundTint="@null"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_power"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                android:text="num"
                android:textColor="@color/text_primary"
                android:background="@drawable/btn_operator_bg"
                app:backgroundTint="@null"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_history"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                android:text="HIST"
                android:textColor="@color/text_primary"
                android:background="@drawable/btn_action_bg"
                app:backgroundTint="@null"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_divide"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="/"
                android:textColor="@color/text_primary"
                android:background="@drawable/btn_operator_bg"
                app:backgroundTint="@null"
                android:textSize="22sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_7"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="7"
                android:textColor="@color/text_primary"
                android:background="@drawable/btn_numeric_bg"
                app:backgroundTint="@null"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_8"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                android:text="8"
                android:textColor="@color/text_primary"
                android:background="@drawable/btn_numeric_bg"
                app:backgroundTint="@null"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_9"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                android:text="9"
                android:textColor="@color/text_primary"
                android:background="@drawable/btn_numeric_bg"
                app:backgroundTint="@null"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_multiply"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="*"
                android:textColor="@color/text_primary"
                android:background="@drawable/btn_operator_bg"
                app:backgroundTint="@null"
                android:textSize="22sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_4"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="4"
                android:textColor="@color/text_primary"
                android:background="@drawable/btn_numeric_bg"
                app:backgroundTint="@null"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_5"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                android:text="5"
                android:textColor="@color/text_primary"
                android:background="@drawable/btn_numeric_bg"
                app:backgroundTint="@null"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_6"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                android:text="6"
                android:textColor="@color/text_primary"
                android:background="@drawable/btn_numeric_bg"
                app:backgroundTint="@null"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_subtract"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="-"
                android:textColor="@color/text_primary"
                android:background="@drawable/btn_operator_bg"
                app:backgroundTint="@null"
                android:textSize="22sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="1"
                android:textColor="@color/text_primary"
                android:background="@drawable/btn_numeric_bg"
                app:backgroundTint="@null"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                android:text="2"
                android:textColor="@color/text_primary"
                android:background="@drawable/btn_numeric_bg"
                app:backgroundTint="@null"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_3"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                android:text="3"
                android:textColor="@color/text_primary"
                android:background="@drawable/btn_numeric_bg"
                app:backgroundTint="@null"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_add"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="+"
                android:textColor="@color/text_primary"
                android:background="@drawable/btn_operator_bg"
                app:backgroundTint="@null"
                android:textSize="22sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_toggle_mode"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="MODE"
                android:textColor="@color/text_primary"
                android:background="@drawable/btn_base_bg"
                app:backgroundTint="@null"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_0"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                android:text="0"
                android:textColor="@color/text_primary"
                android:background="@drawable/btn_numeric_bg"
                app:backgroundTint="@null"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_dot"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                android:text="."
                android:textColor="@color/text_primary"
                android:background="@drawable/btn_numeric_bg"
                app:backgroundTint="@null"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_equals"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="="
                android:textColor="@color/text_primary"
                android:background="@drawable/btn_equal_bg"
                app:backgroundTint="@null"
                android:textSize="22sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
